{
  "name": "Sponsor",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "office_location": {
      "type": "string"
    },
    "state": {
      "type": "string"
    },
    "display_order": {
      "type": "number",
      "default": 0
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive"
      ],
      "default": "active"
    }
  },
  "required": [
    "name",
    "office_location"
  ]
}